# WhatsApp testing profile (isolated)
# Usage:
#   cp back_end/.env.wa_test.example back_end/.env.wa_test
#   and run backend with these env vars loaded (see README note / start script).

# Store LocalAuth session in a dedicated folder (so it won't reuse production session)
WA_SESSION_PATH=./.wwebjs_auth_test

# Do not write WhatsApp connection status to DB during testing
WA_PERSIST_STATUS_TO_DB=false

# Optional: helpful during testing
WA_AUTO_RECONNECT=false
# Increase if you see "auth timeout" during WhatsApp web injection.
WA_AUTH_TIMEOUT_MS=120000
