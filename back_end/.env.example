# Backend server
PORT=5000
BACKEND_PUBLIC_URL=http://localhost:5000

# Database
DB_HOST=localhost
DB_USER=root
DB_PASS=password
DB_NAME=migunani_motor_db

# Auth
JWT_SECRET=your_jwt_secret_key_change_me

# WhatsApp (whatsapp-web.js)
WA_SESSION_PATH=./.wwebjs_auth
# Set to false for temporary testing so WhatsApp connection state is not written to DB.
WA_PERSIST_STATUS_TO_DB=true
# Only accept incoming WhatsApp messages from registered customers.
WA_REQUIRE_REGISTERED_CUSTOMER=true
# Optional: auto-reply text to unregistered numbers (leave blank to disable).
WA_UNREGISTERED_AUTO_REPLY=
# Enable WhatsApp group scraping endpoints (admin-only).
WA_SCRAPE_ENABLED=false
# Optional: set explicit Chrome/Chromium binary path if needed
# WA_CHROME_PATH=/usr/bin/chromium
WA_AUTO_INIT=true
WA_AUTO_RECONNECT=true
WA_CLEAN_PROFILE_LOCKS=true
# whatsapp-web.js inject/auth timeout (default 30000). Increase if startup is slow and you see "auth timeout".
WA_AUTH_TIMEOUT_MS=120000
WA_PROTOCOL_TIMEOUT_MS=120000
WA_INIT_STUCK_MS=45000
WA_RECONNECT_BASE_DELAY_MS=5000
WA_RECONNECT_MAX_DELAY_MS=60000

# Notification outbox worker
NOTIFICATION_OUTBOX_MAX_ATTEMPTS=8
NOTIFICATION_OUTBOX_POLL_MS=2000
NOTIFICATION_OUTBOX_BATCH_LIMIT=50
NOTIFICATION_OUTBOX_RETRY_BASE_MS=2000

# Inventory import (local path gate)
IMPORT_LOCAL_PATH_ENABLED=false
IMPORT_LOCAL_PATH_ALLOWLIST=
